{{ 'collection-services-grid.css' | asset_url | stylesheet_tag }}

<section
  class="collection-services-grid"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}
  style="--collection-grid-bg: {{ section.settings.background_color }}; --collection-grid-text: {{ section.settings.text_color }}; --collection-grid-link: {{ section.settings.link_color }}; --collection-grid-link-hover-bg: {{ section.settings.link_hover_bg }}; --collection-grid-link-hover-text: {{ section.settings.link_hover_text }};"
>
  <div class="collection-services-grid__inner">
    {% if collection != blank %}
    {% paginate collection.products by section.settings.products_per_page %}
      {% if collection.products.size > 0 %}
      <div class="collection-services-grid__list">
        {% for product in collection.products %}
          <article class="collection-services-grid__card">
            <a class="collection-services-grid__card-link" href="{{ product.url | within: collection }}">
              <div class="collection-services-grid__image-wrap">
                {% if product.featured_image != blank %}
                  {{ product.featured_image | image_url: width: 800 | image_tag: class: 'collection-services-grid__image', widths: '400, 600, 800', sizes: '(min-width: 1024px) 33.33vw, (min-width: 768px) 50vw, 100vw', loading: 'lazy', alt: product.featured_image.alt | default: product.title | escape }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'collection-services-grid__image collection-services-grid__image--placeholder' }}
                {% endif %}
              </div>
              <div class="collection-services-grid__card-body">
                <p class="collection-services-grid__title">{{ product.title }}</p>
                {% if product.price_varies %}
                  <p class="collection-services-grid__price">{{ product.price_min | money }} - {{ product.price_max | money }}</p>
                {% else %}
                  <p class="collection-services-grid__price">{{ product.price | money }}</p>
                {% endif %}
                <span class="collection-services-grid__cta">
                  {{ section.settings.view_details_text }}
                  <span class="collection-services-grid__cta-arrow" aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
      {% if paginate.pages > 1 %}
        <nav class="collection-services-grid__pagination" aria-label="Collection pagination">
          {{ paginate | default_pagination }}
        </nav>
      {% endif %}
      {% else %}
        <p class="collection-services-grid__empty">{{ 'collections.general.no_matches' | t | default: 'No products in this collection.' }}</p>
      {% endif %}
    {% endpaginate %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection services grid",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#A6B0A8"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#A6B0A8"
    },
    {
      "type": "color",
      "id": "link_hover_bg",
      "label": "Link hover background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "link_hover_text",
      "label": "Link hover text color",
      "default": "#c5cfc7"
    },
    {
      "type": "text",
      "id": "view_details_text",
      "label": "View details text",
      "default": "VIEW DETAILS"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "label": "Products per page",
      "default": 9
    }
  ],
  "presets": [
    {
      "name": "Collection services grid"
    }
  ]
}
{% endschema %}
