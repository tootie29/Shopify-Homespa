{{ 'group-set.css' | asset_url | stylesheet_tag }}

<section
  class="group-set"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}
  style="--group-set-bg: {{ section.settings.background_color }}; --group-set-card-bg: {{ section.settings.card_background_color }};"
>
  <div class="group-set__inner">
    {% if section.settings.title != blank or section.settings.intro != blank %}
      <header class="group-set__header">
        {% if section.settings.title != blank %}
          <h2 class="group-set__heading">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.intro != blank %}
          <div class="group-set__intro rte">
            {{ section.settings.intro }}
          </div>
        {% endif %}
      </header>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="group-set__grid">
        {% for block in section.blocks %}
          {% capture card_inner %}
            <div class="group-set__card-inner">
              {% if block.settings.title != blank %}
                <h3 class="group-set__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.tagline != blank %}
                <p class="group-set__tagline">{{ block.settings.tagline }}</p>
              {% endif %}
              {% if block.settings.best_for != blank %}
                <p class="group-set__best-for">
                  <strong class="group-set__best-for-label">Best for:</strong>
                  <span class="group-set__best-for-text">{{ block.settings.best_for }}</span>
                </p>
              {% endif %}
              {% if block.settings.services != blank %}
                <div class="group-set__services rte">
                  {{ block.settings.services }}
                </div>
              {% endif %}
              {% if block.settings.benefit != blank or block.settings.price != blank %}
                <p class="group-set__benefit-line">
                  {% if block.settings.benefit != blank %}
                    <span class="group-set__benefit-copy">Benefit: {{ block.settings.benefit }}</span>
                  {% endif %}
                  {% if block.settings.price != blank %}
                    <strong class="group-set__price">{% if block.settings.benefit != blank %} {% endif %}{{ block.settings.price }}</strong>
                  {% endif %}
                </p>
              {% endif %}
            </div>
          {% endcapture %}

          <article class="group-set__card" {{ block.shopify_attributes }}>
            {% if block.settings.card_link != blank %}
              <a class="group-set__card-link" href="{{ block.settings.card_link }}">
                {{ card_inner }}
              </a>
            {% else %}
              {{ card_inner }}
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Group Set",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#00000000"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Signature Wellness Sets"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text"
    }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Set",
      "settings": [
