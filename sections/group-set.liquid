        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "750 Php"
        },
        {
          "type": "url",
          "id": "card_link",
          "label": "Link (optional)",
          "info": "Makes the entire card clickable."
        }
      ]
    }
  ],
  "presets": [
