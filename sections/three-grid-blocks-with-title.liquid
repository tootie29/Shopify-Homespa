{{ 'three-grid-blocks-with-title.css' | asset_url | stylesheet_tag }}

<section
  class="three-grid-blocks"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}
  style="--section-bg: {{ section.settings.background_color }};"
>
  {% if section.settings.decorative_image != blank %}
    <div class="three-grid-blocks__deco" aria-hidden="true">
      {{ section.settings.decorative_image | image_url: width: 400 | image_tag: class: 'three-grid-blocks__deco-image', widths: '200, 400', loading: 'lazy', alt: '' }}
    </div>
  {% endif %}
  <div class="three-grid-blocks__inner">
    <div class="three-grid-blocks__header">
      {% if section.settings.title != blank %}
        <h2 class="three-grid-blocks__heading">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="three-grid-blocks__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
    {% if section.blocks.size > 0 %}
      <div class="three-grid-blocks__row">
        {% for block in section.blocks %}
          <div class="three-grid-blocks__card" {{ block.shopify_attributes }}>
            <div class="three-grid-blocks__card-image-wrap">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: class: 'three-grid-blocks__card-image', widths: '300, 450, 600', sizes: '(min-width: 1024px) 33.33vw, (min-width: 768px) 50vw, 100vw', loading: 'lazy', alt: block.settings.image.alt | default: block.settings.title | escape }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'three-grid-blocks__card-image three-grid-blocks__card-image--placeholder' }}
              {% endif %}
            </div>
            <div class="three-grid-blocks__card-body">
              {% if block.settings.title != blank %}
                <h3 class="three-grid-blocks__card-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="three-grid-blocks__card-description">
                  {{ block.settings.description }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Three Grid Blocks",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#faf9f7"
    },
    {
      "type": "image_picker",
      "id": "decorative_image",
      "label": "Decorative image (left edge)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Work With Us?"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>This is just placeholder text. Don't be alarmed, this is just here to fill up space since your finalized copy isn't ready yet. Once we have your content finalized, we'll replace this placeholder text with your real content.</p>"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Block",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "This is just placeholder text"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>This is just placeholder text. Don't be alarmed, this is just here to fill up space since your finalized copy isn't ready yet.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three Grid Blocks",
      "blocks": [
        { "type": "block", "settings": { "title": "This is just placeholder text", "description": "<p>This is just placeholder text. Don't be alarmed, this is just here to fill up space since your finalized copy isn't ready yet.</p>" } },
        { "type": "block", "settings": { "title": "This is just placeholder text", "description": "<p>This is just placeholder text. Don't be alarmed, this is just here to fill up space since your finalized copy isn't ready yet.</p>" } },
        { "type": "block", "settings": { "title": "This is just placeholder text", "description": "<p>This is just placeholder text. Don't be alarmed, this is just here to fill up space since your finalized copy isn't ready yet.</p>" } }
      ]
    }
  ]
}
{% endschema %}
