<section
  class="image-text-cta"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}
  style="--section-bg: {{ section.settings.background_color }};"
>
  <div class="image-text-cta__inner">
    <div class="image-text-cta__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'image-text-cta__image', widths: '600, 900, 1200, 1600', alt: section.settings.image.alt }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg image-text-cta__image' }}
      {% endif %}
    </div>
    <div class="image-text-cta__content">
      <div class="image-text-cta__content-inner">
        {% if section.settings.title != blank %}
          <h2 class="image-text-cta__title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="image-text-cta__description">{{ section.settings.description }}</p>
        {% endif %}
        {% if section.settings.button_label != blank %}
          {% if section.settings.button_link != blank %}
            <a class="button image-text-cta__button" href="{{ section.settings.button_link }}">
              {{ section.settings.button_label }}
            </a>
          {% else %}
            <span class="button image-text-cta__button">{{ section.settings.button_label }}</span>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image text CTA",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "This is just a placeholder headline, we will replace it once your website copy is finalized."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "This is just placeholder text. Don’t be alarmed, this is just here to fill up space since your finalized copy isn’t ready yet."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Image text CTA"
    }
  ]
}
{% endschema %}
