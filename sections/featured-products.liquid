{{ 'featured-products.css' | asset_url | stylesheet_tag }}

<section
  class="featured-products"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}
  style="--section-bg: {{ section.settings.background_color }};"
>
  <div class="featured-products__inner">
    <div class="featured-products__intro">
      <div class="featured-products__intro-text">
        {% if section.settings.title != blank %}
          <h2 class="featured-products__title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="featured-products__description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
      {% if section.settings.button_text != blank %}
        {% if section.settings.button_url != blank %}
          <a class="button featured-products__button" href="{{ section.settings.button_url }}">
            {{ section.settings.button_text }}
          </a>
        {% else %}
          <span class="button featured-products__button">{{ section.settings.button_text }}</span>
        {% endif %}
      {% endif %}
    </div>

    <div class="featured-products__grid">
      <div class="featured-products__grid-main">
        {% assign primary_block = section.blocks | first %}
        {% if primary_block != blank %}
          {% if primary_block.settings.link != blank %}
            <a
              class="featured-products__card featured-products__card--primary"
              href="{{ primary_block.settings.link }}"
              {{ primary_block.shopify_attributes }}
            >
              <div class="featured-products__image-wrap">
                {% if primary_block.settings.image != blank %}
                  {{ primary_block.settings.image | image_url: width: 1600 | image_tag: class: 'featured-products__image', widths: '600, 900, 1200, 1600', alt: primary_block.settings.image.alt }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg featured-products__image' }}
                {% endif %}
              </div>
              <div class="featured-products__card-meta">
                {% if primary_block.settings.title != blank %}
                  <h3 class="featured-products__card-title">{{ primary_block.settings.title }}</h3>
                {% endif %}
                {% if primary_block.settings.price_text != blank %}
                  <p class="featured-products__card-price">{{ primary_block.settings.price_text }}</p>
                {% endif %}
                <span class="featured-products__card-link">
                  View Details
                  <span class="featured-products__card-link-arrow" aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          {% else %}
            <div class="featured-products__card featured-products__card--primary" {{ primary_block.shopify_attributes }}>
              <div class="featured-products__image-wrap">
                {% if primary_block.settings.image != blank %}
                  {{ primary_block.settings.image | image_url: width: 1600 | image_tag: class: 'featured-products__image', widths: '600, 900, 1200, 1600', alt: primary_block.settings.image.alt }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg featured-products__image' }}
                {% endif %}
              </div>
