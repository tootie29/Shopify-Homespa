                  </svg>
                  {% if primary_block.settings.title != blank %}
                    <h3 class="featured-products__card-title">{{ primary_block.settings.title }}</h3>
                  {% endif %}
                </div>
                <div class="featured-products__card-meta-content">
                  {% if primary_block.settings.price_text != blank %}
                    <p class="featured-products__card-price">{{ primary_block.settings.price_text }}</p>
                  {% endif %}
                  <span class="featured-products__card-link">
                    View Details
                    <span class="featured-products__card-link-arrow" aria-hidden="true">→</span>
                  </span>
                </div>
              </div>
            </div>
          {% endif %}
        {% endif %}
      </div>

