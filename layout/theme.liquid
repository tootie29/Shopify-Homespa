<!doctype html>
<html>
<head>
  <title>{{ page_title }}</title>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <meta name="description" content="{{ page_description | escape }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no">
  {{ content_for_header }} <!-- Header hook for plugins -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css">
  {{ 'application.css' | asset_url | stylesheet_tag }}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js" defer></script>
  {{ 'application.js' | asset_url | script_tag }}
</head>
<body>

  <div class="top-bar">
    <div class="top-bar__inner">
      <div class="top-bar__item">
        {% if settings.top_bar_address != blank %}
          <span class="icon icon--location" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="presentation" focusable="false">
              <path d="M12 2.5c-3.7 0-6.7 3-6.7 6.7 0 4.8 6.7 12.3 6.7 12.3s6.7-7.5 6.7-12.3c0-3.7-3-6.7-6.7-6.7zm0 9.3a2.6 2.6 0 1 1 0-5.2 2.6 2.6 0 0 1 0 5.2z"></path>
            </svg>
          </span>
          <span class="top-bar__text">{{ settings.top_bar_address }}</span>
        {% endif %}
      </div>
      <div class="top-bar__item top-bar__item--right">
        {% if settings.top_bar_phone != blank %}
          <a class="top-bar__link" href="tel:{{ settings.top_bar_phone | replace: ' ', '' }}">
            <span class="icon icon--phone" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M6.6 3.8c.5-.5 1.3-.5 1.8 0l2.2 2.2c.5.5.5 1.3 0 1.8l-1.3 1.3c1.1 2.3 3 4.2 5.3 5.3l1.3-1.3c.5-.5 1.3-.5 1.8 0l2.2 2.2c.5.5.5 1.3 0 1.8l-1.2 1.2c-.9.9-2.3 1.2-3.5.8-5.3-1.7-9.6-6-11.3-11.3-.4-1.2-.1-2.6.8-3.5l1.2-1.2z"></path>
              </svg>
            </span>
            <span class="top-bar__text">{{ settings.top_bar_phone }}</span>
          </a>
        {% endif %}
        {% if settings.top_bar_email != blank %}
          <a class="top-bar__link" href="mailto:{{ settings.top_bar_email }}">
            <span class="icon icon--email" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M4 5.5h16a1.5 1.5 0 0 1 1.5 1.5v10A1.5 1.5 0 0 1 20 18.5H4A1.5 1.5 0 0 1 2.5 17V7A1.5 1.5 0 0 1 4 5.5zm8 6.2 8-4.7V7l-8 4.7L4 7v.1l8 4.6z"></path>
              </svg>
            </span>
            <span class="top-bar__text">{{ settings.top_bar_email }}</span>
          </a>
        {% endif %}
        <div class="top-bar__social">
          {% if settings.social_facebook != blank %}
            <a class="social-link" href="{{ settings.social_facebook }}" aria-label="Facebook">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M13.5 8.2V6.7c0-.8.5-1.2 1.1-1.2h1.6V3.1h-2.2c-2.2 0-3.5 1.4-3.5 3.4v1.7H8.9v2.5h1.6v8.2h3V10.7h2.1l.4-2.5h-2.5z"></path>
              </svg>
            </a>
          {% endif %}
          {% if settings.social_twitter != blank %}
            <a class="social-link" href="{{ settings.social_twitter }}" aria-label="Twitter">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M19.8 7.2c.8-.5 1.4-1.2 1.7-2-.7.4-1.5.6-2.3.8-.7-.7-1.6-1.1-2.7-1.1-2 0-3.6 1.6-3.6 3.6 0 .3 0 .5.1.8-3-.2-5.7-1.6-7.5-3.8-.3.5-.5 1.2-.5 1.8 0 1.2.6 2.3 1.6 2.9-.6 0-1.1-.2-1.6-.4v.1c0 1.7 1.2 3.1 2.8 3.4-.3.1-.6.1-1 .1-.2 0-.5 0-.7-.1.5 1.4 1.8 2.4 3.4 2.4-1.3 1-2.9 1.6-4.7 1.6h-1c1.7 1.1 3.7 1.7 5.8 1.7 7 0 10.8-5.8 10.8-10.8v-.5c.7-.5 1.3-1.1 1.8-1.8-.6.3-1.3.5-2 .6z"></path>
              </svg>
            </a>
          {% endif %}
          {% if settings.social_instagram != blank %}
            <a class="social-link" href="{{ settings.social_instagram }}" aria-label="Instagram">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M16.8 3.5H7.2a3.7 3.7 0 0 0-3.7 3.7v9.6a3.7 3.7 0 0 0 3.7 3.7h9.6a3.7 3.7 0 0 0 3.7-3.7V7.2a3.7 3.7 0 0 0-3.7-3.7zm2.1 13.3a2.1 2.1 0 0 1-2.1 2.1H7.2a2.1 2.1 0 0 1-2.1-2.1V7.2a2.1 2.1 0 0 1 2.1-2.1h9.6a2.1 2.1 0 0 1 2.1 2.1v9.6z"></path>
                <path d="M12 7.8a4.2 4.2 0 1 0 0 8.4 4.2 4.2 0 0 0 0-8.4zm0 6.8a2.6 2.6 0 1 1 0-5.2 2.6 2.6 0 0 1 0 5.2z"></path>
                <circle cx="17.3" cy="6.7" r="1"></circle>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <header class="site-header {{ settings.header_bg }}">
    <div class="site-header__inner">
      <div class="site-header__logo">
        <a class="logo-link" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {% if settings.header_logo != blank %}
            {{ settings.header_logo | image_url: width: 420 | image_tag: class: 'site-logo', widths: '120, 180, 240, 300, 360, 420', alt: shop.name }}
          {% else %}
            <span class="logo-text">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>
      <button class="site-header__toggle" type="button" aria-expanded="false" aria-controls="site-navigation" aria-label="Menu">
        <span class="site-header__toggle-bar"></span>
        <span class="site-header__toggle-bar"></span>
        <span class="site-header__toggle-bar"></span>
      </button>
      <nav class="site-header__nav" id="site-navigation" aria-label="Main navigation">
        {% if settings.header_menu != blank %}
          <ul class="main-menu">
            {% for link in linklists[settings.header_menu].links %}
              <li class="main-menu__item">
                <a class="main-menu__link" href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </nav>
      <div class="site-header__cta">
        {% if settings.header_cta_text != blank and settings.header_cta_link != blank %}
          <a class="button button--header" href="{{ settings.header_cta_link }}">
            <span class="site-header__cta-text">{{ settings.header_cta_text }}</span>
            <span class="site-header__cta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false" width="20" height="20">
                <path d="M6.6 3.8c.5-.5 1.3-.5 1.8 0l2.2 2.2c.5.5.5 1.3 0 1.8l-1.3 1.3c1.1 2.3 3 4.2 5.3 5.3l1.3-1.3c.5-.5 1.3-.5 1.8 0l2.2 2.2c.5.5.5 1.3 0 1.8l-1.2 1.2c-.9.9-2.3 1.2-3.5.8-5.3-1.7-9.6-6-11.3-11.3-.4-1.2-.1-2.6.8-3.5l1.2-1.2z" fill="currentColor"/>
              </svg>
            </span>
          </a>
        {% endif %}
      </div>
    </div>
  </header>

  <main role="main">
    {{ content_for_layout }}
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <div class="site-footer__col site-footer__brand">
        <a class="logo-link" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {% if settings.footer_logo != blank %}
            {{ settings.footer_logo | image_url: width: 420 | image_tag: class: 'site-logo', widths: '140, 200, 280, 360, 420', alt: shop.name }}
          {% else %}
            <span class="logo-text">{{ shop.name }}</span>
          {% endif %}
        </a>
        {% if settings.footer_description != blank %}
          <p class="site-footer__text">{{ settings.footer_description }}</p>
        {% endif %}
        <div class="site-footer__social">
          {% if settings.social_facebook != blank %}
            <a class="social-link" href="{{ settings.social_facebook }}" aria-label="Facebook">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M13.5 8.2V6.7c0-.8.5-1.2 1.1-1.2h1.6V3.1h-2.2c-2.2 0-3.5 1.4-3.5 3.4v1.7H8.9v2.5h1.6v8.2h3V10.7h2.1l.4-2.5h-2.5z"></path>
              </svg>
            </a>
          {% endif %}
          {% if settings.social_twitter != blank %}
            <a class="social-link" href="{{ settings.social_twitter }}" aria-label="Twitter">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M19.8 7.2c.8-.5 1.4-1.2 1.7-2-.7.4-1.5.6-2.3.8-.7-.7-1.6-1.1-2.7-1.1-2 0-3.6 1.6-3.6 3.6 0 .3 0 .5.1.8-3-.2-5.7-1.6-7.5-3.8-.3.5-.5 1.2-.5 1.8 0 1.2.6 2.3 1.6 2.9-.6 0-1.1-.2-1.6-.4v.1c0 1.7 1.2 3.1 2.8 3.4-.3.1-.6.1-1 .1-.2 0-.5 0-.7-.1.5 1.4 1.8 2.4 3.4 2.4-1.3 1-2.9 1.6-4.7 1.6h-1c1.7 1.1 3.7 1.7 5.8 1.7 7 0 10.8-5.8 10.8-10.8v-.5c.7-.5 1.3-1.1 1.8-1.8-.6.3-1.3.5-2 .6z"></path>
              </svg>
            </a>
          {% endif %}
          {% if settings.social_instagram != blank %}
            <a class="social-link" href="{{ settings.social_instagram }}" aria-label="Instagram">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M16.8 3.5H7.2a3.7 3.7 0 0 0-3.7 3.7v9.6a3.7 3.7 0 0 0 3.7 3.7h9.6a3.7 3.7 0 0 0 3.7-3.7V7.2a3.7 3.7 0 0 0-3.7-3.7zm2.1 13.3a2.1 2.1 0 0 1-2.1 2.1H7.2a2.1 2.1 0 0 1-2.1-2.1V7.2a2.1 2.1 0 0 1 2.1-2.1h9.6a2.1 2.1 0 0 1 2.1 2.1v9.6z"></path>
                <path d="M12 7.8a4.2 4.2 0 1 0 0 8.4 4.2 4.2 0 0 0 0-8.4zm0 6.8a2.6 2.6 0 1 1 0-5.2 2.6 2.6 0 0 1 0 5.2z"></path>
                <circle cx="17.3" cy="6.7" r="1"></circle>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
      <div class="site-footer__col">
        {% if settings.footer_services_menu != blank %}
          <h3 class="site-footer__heading">Services</h3>
          <ul class="site-footer__menu">
            {% for link in linklists[settings.footer_services_menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
      <div class="site-footer__col">
        {% if settings.footer_quick_links_menu != blank %}
          <h3 class="site-footer__heading">Quick Links</h3>
          <ul class="site-footer__menu">
            {% for link in linklists[settings.footer_quick_links_menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
      <div class="site-footer__col site-footer__subscribe">
        <h3 class="site-footer__heading">{{ settings.footer_subscribe_heading }}</h3>
        {% if settings.footer_subscribe_description != blank %}
          <p class="site-footer__text">{{ settings.footer_subscribe_description }}</p>
        {% endif %}
        {% if settings.footer_subscribe_action != blank %}
          <form class="site-footer__form" action="{{ settings.footer_subscribe_action }}" method="post" target="_blank" novalidate>
            <label class="visually-hidden" for="FooterEmail">Email address</label>
            <input id="FooterEmail" class="site-footer__input" type="email" name="EMAIL" placeholder="{{ settings.footer_subscribe_placeholder }}" required>
            <button class="button button--subscribe" type="submit">{{ settings.footer_subscribe_button }}</button>
          </form>
        {% endif %}
      </div>
    </div>
  </footer>
  <section class="site-copyright">
    <p class="site-copyright__text">{{ settings.footer_copyright }}</p>
  </section>
</body>
</html>
